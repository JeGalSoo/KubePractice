# 빌드 결과물 및 임시 파일
build/
bin/
out/
target/
.gradle/
*.jar

# 특정 jar만 포함하고 싶을 때 (예: 그래들 래퍼)
!gradle/wrapper/gradle-wrapper.jar

# IDE 설정 파일 (개인 설정이므로 공유하지 않음)
.idea/
.vscode/
*.iml
*.iws
*.ipr
.settings/
.classpath
.project
docs
config-repo

# 환경 변수 파일 (민감 정보 포함 - 절대 커밋 금지)
.env
.env.local
.env.production
.env.development

# 프론트엔드 의존성
node_modules/

# 업로드된 파일 (사용자 데이터)
uploads/