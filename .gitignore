# ============================
# 빌드 결과물 및 임시 파일
# ============================
build/
bin/
out/
target/
.gradle/
*.jar

# 그래들 래퍼 jar는 예외 포함 (버전 고정을 위해 커밋 필요)
!gradle/wrapper/gradle-wrapper.jar

# ============================
# IDE 설정 파일 (개인 설정이므로 공유하지 않음)
# ============================
.idea/
.vscode/
*.iml
*.iws
*.ipr
.settings/
.classpath
.project
docs
config-repo
portfolio


# ============================
# 환경 변수 파일 (민감 정보 포함 - 절대 커밋 금지)
# ============================
.env
.env.local
.env.production
.env.development
.env.*.local

# ============================
# 프론트엔드 의존성 및 빌드
# ============================
node_modules/
dist/
dist-ssr/

# ============================
# 업로드된 파일 (사용자 데이터)
# ============================
uploads/

# ============================
# 로그 파일
# ============================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 프론트엔드 빌드 오류 임시 파일 (Vite 등)
errors.txt
errors-utf8.txt

# ============================
# OS 생성 파일
# ============================
.DS_Store
Thumbs.db
Desktop.ini

# ============================
# Spring Boot 테스트 캐시
# ============================
.testcontainers.properties

# ============================
# 로컬 전용 문서/설정 (의도적으로 제외)
# docs/       → 포트폴리오 문서: 공유 필요 시 아래 주석 해제
# config-repo → Config Server 설정: 별도 저장소 또는 보안상 제외
# ============================
docs
config-repo