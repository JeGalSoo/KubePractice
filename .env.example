# =====================================================
#  환경 변수 템플릿 (실제 값은 .env 파일에 작성)
#  이 파일을 복사해서 .env 파일을 만들고 값을 채워 사용하세요:
#    cp .env.example .env
# =====================================================

# MySQL 공통
MYSQL_ROOT_PASSWORD=your_root_password_here

# MySQL main DB (authdb)
MYSQL_DATABASE=authdb
MYSQL_USER=authuser
MYSQL_PASSWORD=your_main_db_password_here

# MySQL archive DB (archivedb)
MYSQL_ARCHIVE_DATABASE=archivedb
MYSQL_ARCHIVE_USER=archiveuser
MYSQL_ARCHIVE_PASSWORD=your_archive_db_password_here
